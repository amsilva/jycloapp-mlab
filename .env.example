# Copy this file to .env (never commit .env to git!)
# Set these variables in PythonAnywhere's Web tab > Environment Variables section

# MySQL connection string for PythonAnywhere
# Format: mysql+pymysql://username:password@username.mysql.pythonanywhere-services.com/username$dbname
DATABASE_URL=mysql+pymysql://YOUR_USER:YOUR_PASS@YOUR_USER.mysql.pythonanywhere-services.com/YOUR_USER$jycloapp

# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-string
